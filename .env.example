# ACB Trader — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── MT5 Broker Connection ─────────────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=ICMarketsSC-Demo  # or your broker's server name

# ── Telegram Alerts ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_PROXY=

# ── Optional: Claude AI validation call ──────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
